{
  "manifest_version": 3,
  "name": "Engagr WebBridge",
  "description": "Personal Chrome bridge for Engagr Mini App workflows — LinkedIn & X/Twitter.",
  "version": "0.5.0",
  "action": {
    "default_title": "Engagr WebBridge",
    "default_popup": "src/popup.html"
  },
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://www.twitter.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*.vercel.app/*",
    "https://*.railway.app/*",
    "https://engagr-production.up.railway.app/*",
    "https://*.up.railway.app/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*"
      ],
      "js": [
        "src/linkedin_parser.js",
        "src/linkedin_actions.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.twitter.com/*"
      ],
      "js": [
        "src/x_parser.js",
        "src/x_actions.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://*.vercel.app/*",
        "https://*.railway.app/*",
        "https://*.up.railway.app/*"
      ],
      "js": [
        "src/miniapp_bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
